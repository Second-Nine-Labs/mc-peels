{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:api"],
      "port": 3000
    },
    {
      "name": "mobile-web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "apps/mobile", "run", "web"],
      "port": 8081
    },
    {
      "name": "mobile-web-preview",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "apps/mobile", "run", "web", "--", "--port", "8090"],
      "port": 8090
    }
  ]
}

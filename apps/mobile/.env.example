# MC Peels app environment.
# Copy to .env (or configure in your EAS/hosting env) and fill in real values.
#
# All EXPO_PUBLIC_* variables are embedded in the client bundle and are visible
# to anyone with the app — never put secrets here. The Supabase anon key and
# project URL are designed to be public; all data access goes through the
# MC Peels REST API using the signed-in user's Supabase access token.

# Supabase project URL (used for auth only)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon (publishable) key
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# MC Peels API origin, WITHOUT the /api/v1 suffix (the app appends it)
# e.g. http://localhost:3000 in development
EXPO_PUBLIC_API_URL=https://mc-peels.example.com

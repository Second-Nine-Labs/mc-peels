# --- Database (Supabase Postgres connection string; use the pooled connection for serverless) ---
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# --- Supabase Auth ---
# Project URL, e.g. https://<project-ref>.supabase.co
SUPABASE_URL=
# Legacy HS256 JWT secret (Project Settings -> API -> JWT Secret).
# If unset, tokens are verified against the project's JWKS endpoint instead.
SUPABASE_JWT_SECRET=

# --- Anthropic (natural-language request parsing) ---
ANTHROPIC_API_KEY=
# Model used for parsing grocery requests into line items.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Instacart Developer Platform ---
# Single server-side partner API key. Never exposed to clients (PRD section 3).
INSTACART_API_KEY=
# "development" -> https://connect.dev.instacart.tools, "production" -> https://connect.instacart.com
INSTACART_ENV=development

# --- App ---
# Used for Instacart landing-page linkback, e.g. https://mcpeels.app
APP_BASE_URL=
PORT=3000

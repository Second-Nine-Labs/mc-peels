# --- Database (Supabase Postgres connection string; use the pooled connection for serverless) ---
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# --- Supabase Auth ---
# Project URL, e.g. https://<project-ref>.supabase.co
SUPABASE_URL=
# Legacy HS256 JWT secret (Project Settings -> API -> JWT Secret).
# If unset, tokens are verified against the project's JWKS endpoint instead.
SUPABASE_JWT_SECRET=

# --- Anthropic (natural-language request parsing) ---
ANTHROPIC_API_KEY=
# Model used for parsing grocery requests into line items.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Instacart Developer Platform ---
# Single server-side partner API key. Never exposed to clients (PRD section 3).
INSTACART_API_KEY=
# "development" -> https://connect.dev.instacart.tools, "production" -> https://connect.instacart.com
INSTACART_ENV=development

# --- App ---
# Used for Instacart landing-page linkback, e.g. https://mcpeels.app
APP_BASE_URL=
PORT=3000

# --- Fulfillment rails (parallel rails + price comparison) ---
# Enabled providers, comma-separated, in display order. Default "instacart"
# keeps the server single-rail; flip to enable the comparison:
# FULFILLMENT_PROVIDERS=instacart,kroger,doordash,ubereats
FULFILLMENT_PROVIDERS=instacart

# Kroger Public API app credentials (developer.kroger.com; Products, Locations,
# and Cart APIs). Required before the kroger provider will activate.
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=
# Production API host; use https://api-ce.kroger.com for the certification env.
KROGER_BASE_URL=https://api.kroger.com

# 32 bytes base64 (openssl rand -base64 32). Encrypts linked-account OAuth
# tokens at rest; also keys the OAuth state JWT. Required for kroger.
TOKEN_ENCRYPTION_KEY=

# Public origin of THIS API — the base for the registered Kroger redirect_uri:
# <API_PUBLIC_URL>/api/v1/connect/kroger/callback
# e.g. http://localhost:3000 in development
API_PUBLIC_URL=

# Origins allowed as post-OAuth return destinations (mcpeels:// and localhost
# are always allowed).
CONNECT_RETURN_ORIGINS=https://mc-peels.secondninelabs.com

# Search-candidate cache TTL for price quotes, in minutes.
QUOTE_CACHE_TTL_MINUTES=360
